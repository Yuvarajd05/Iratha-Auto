# Odoo Backend Configuration Template
# Copy this file to .env.local and update the values for your environment

# The base URL of the Odoo server (default for local development)
NEXT_PUBLIC_ODOO_BASE_URL=http://localhost:8069

# The target Odoo database name
ODOO_DB_NAME=odoo

# Odoo API credentials (if needed for authenticated requests)
# ODOO_API_KEY=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
